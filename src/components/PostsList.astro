---
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
  title: string;
  titleId: string;
  headingLevel?: "h1" | "h2";
}

const { posts, title, titleId, headingLevel = "h2" } = Astro.props;
const Heading = headingLevel;

const formatter = new Intl.DateTimeFormat("en", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort(
  (a, b) => a.localeCompare(b),
);

const tagStyleClasses = [
  "text-[#7890ad]",
  "text-[#5aa6a0]",
  "text-[#c7ab2c]",
  "text-[#c94d4d]",
  "text-[#7169dd]",
];

const tagStyles = new Map(
  tags.map((tag, index) => [
    tag,
    tagStyleClasses[index % tagStyleClasses.length],
  ]),
);
---

<section class="[&+&]:mt-[clamp(3rem,6vw,4rem)]" aria-labelledby={titleId}>
  <header
    class="mb-3 flex items-center justify-between gap-6 max-[36rem]:flex-col max-[36rem]:items-start"
  >
    <div class="flex items-baseline gap-3">
      <Heading
        id={titleId}
        class="m-0 text-xl leading-none font-medium text-text"
      >
        {title}
      </Heading>
      <span class="m-0 text-sm leading-none font-normal text-subtle">
        {posts.length}
      </span>
    </div>
  </header>

  {
    posts.length > 0 ? (
      <ol class="m-0 grid list-none p-0">
        {posts.map((post) => (
          <li class="border-t border-line first:border-t-0">
            <a
              href={`/posts/${post.id}/`}
              class="group grid min-h-14 grid-cols-[minmax(0,1fr)_minmax(9rem,16rem)_7.75rem] items-center gap-4 py-3 max-[36rem]:min-h-0 max-[36rem]:grid-cols-1 max-[36rem]:gap-[0.45rem] max-[36rem]:py-[0.85rem]"
            >
              <span class="text-base leading-[1.45] font-light text-text group-hover:text-accent group-hover:underline group-hover:decoration-[0.06em] group-hover:underline-offset-[0.12em] group-focus-visible:text-accent group-focus-visible:underline group-focus-visible:decoration-[0.06em] group-focus-visible:underline-offset-[0.12em]">
                {post.data.title}
              </span>
              <span
                class="flex flex-wrap justify-end gap-[0.45rem] text-sm leading-[1.4] text-subtle max-[36rem]:justify-start"
                aria-label="Tags"
              >
                {post.data.tags.map((tag, index) => (
                  <>
                    {index > 0 ? <span aria-hidden="true">·</span> : null}
                    <span class:list={tagStyles.get(tag)}>{tag}</span>
                  </>
                ))}
              </span>
              <time
                class="justify-self-end whitespace-nowrap text-sm leading-[1.35] font-normal text-subtle max-[36rem]:justify-self-start"
                datetime={post.data.date.toISOString()}
              >
                {formatter.format(post.data.date)}
              </time>
            </a>
          </li>
        ))}
      </ol>
    ) : (
      <p class="m-0 pt-1 text-base leading-[1.4] text-muted" role="status">
        No posts yet.
      </p>
    )
  }
</section>
